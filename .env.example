# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trova?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_must_be_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_must_be_long_and_secure
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic Claude API (Future Use)
ANTHROPIC_API_KEY=

# Paystack Payment Gateway (Future Use)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Resend Email Service (Future Use)
RESEND_API_KEY=

# Frontend Application Client URL
CLIENT_URL=http://localhost:5173
